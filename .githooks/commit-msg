#!/usr/bin/env bash
set -euo pipefail

RED='\033[0;31m'
YELLOW='\033[1;33m'
GREEN='\033[0;32m'
BOLD='\033[1m'
NC='\033[0m'

COMMIT_MSG_FILE="$1"
COMMIT_MSG=$(head -1 "$COMMIT_MSG_FILE")

# ---------------------------------------------------------------------------
# Allow merge commits and reverts generated by Git
# ---------------------------------------------------------------------------
if [[ "$COMMIT_MSG" =~ ^Merge\ |^Revert\ |^Merged\ ]]; then
    exit 0
fi

# ---------------------------------------------------------------------------
# Conventional Commits: <type>(<scope>): <description>
# ---------------------------------------------------------------------------
VALID_TYPES="feat|fix|docs|refactor|test|chore|perf|ci|style|build|revert"
VALID_SCOPES="identity|inventory|reservation|delivery|platform|gateway|common|infra"
PATTERN="^(${VALID_TYPES})\((${VALID_SCOPES})\): [a-z].*[^.]$"

# Check first line length
if [[ ${#COMMIT_MSG} -gt 72 ]]; then
    echo -e "${RED}${BOLD}ERROR:${NC} Commit message first line exceeds 72 characters (${#COMMIT_MSG})."
    echo -e "  Current: ${RED}${COMMIT_MSG}${NC}"
    echo ""
    exit 1
fi

# Check format
if [[ ! "$COMMIT_MSG" =~ $PATTERN ]]; then
    echo -e "${RED}${BOLD}ERROR:${NC} Commit message does not follow Conventional Commits format."
    echo ""
    echo -e "  Expected: ${GREEN}<type>(<scope>): <description>${NC}"
    echo ""
    echo -e "  Types:  ${YELLOW}feat, fix, docs, refactor, test, chore, perf, ci, style, build, revert${NC}"
    echo -e "  Scopes: ${YELLOW}identity, inventory, reservation, delivery, platform, gateway, common, infra${NC}"
    echo ""
    echo -e "  Rules:"
    echo -e "    - Description must start with a ${YELLOW}lowercase${NC} letter"
    echo -e "    - Description must ${YELLOW}not end with a period${NC}"
    echo -e "    - First line must be ${YELLOW}72 characters or fewer${NC}"
    echo ""
    echo -e "  Examples:"
    echo -e "    ${GREEN}feat(identity): add OAuth2 login flow${NC}"
    echo -e "    ${GREEN}fix(reservation): handle payment race condition${NC}"
    echo -e "    ${GREEN}chore(infra): upgrade to Gradle 9.4${NC}"
    echo ""
    echo -e "  Got: ${RED}${COMMIT_MSG}${NC}"
    echo ""
    exit 1
fi

exit 0
