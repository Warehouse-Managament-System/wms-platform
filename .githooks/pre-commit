#!/usr/bin/env bash
set -euo pipefail

RED='\033[0;31m'
YELLOW='\033[1;33m'
GREEN='\033[0;32m'
BOLD='\033[1m'
NC='\033[0m'

errors=0
warnings=0

# ---------------------------------------------------------------------------
# 1. Branch name validation
# ---------------------------------------------------------------------------
BRANCH=$(git symbolic-ref --short HEAD 2>/dev/null || echo "HEAD")

EXEMPT_PATTERN='^(main|master|develop|release/.+|HEAD)$'

if [[ ! "$BRANCH" =~ $EXEMPT_PATTERN ]]; then
    VALID_TYPES="feature|fix|hotfix|refactor|docs|test|chore|ci|perf|build"
    VALID_SERVICES="identity-service|inventory-service|reservation-service|delivery-service|platform-service|api-gateway|config-server|eureka-server|wms-common|infra|all"
    BRANCH_PATTERN="^(${VALID_TYPES})/(${VALID_SERVICES})/[a-z0-9-]+/[a-z0-9-]+$"

    if [[ ! "$BRANCH" =~ $BRANCH_PATTERN ]]; then
        echo -e "${RED}${BOLD}ERROR:${NC} Branch name ${RED}\"$BRANCH\"${NC} does not follow the required format."
        echo ""
        echo -e "  Expected: ${GREEN}<type>/<service>/<author>/<description>${NC}"
        echo ""
        echo -e "  Types:    ${YELLOW}feature, fix, hotfix, refactor, docs, test, chore, ci, perf, build${NC}"
        echo -e "  Services: ${YELLOW}identity-service, inventory-service, reservation-service, delivery-service,${NC}"
        echo -e "            ${YELLOW}platform-service, api-gateway, config-server, eureka-server, wms-common, infra, all${NC}"
        echo -e "  Author:   ${YELLOW}lowercase alphanumeric + hyphens${NC}"
        echo -e "  Desc:     ${YELLOW}kebab-case${NC}"
        echo ""
        echo -e "  Example:  ${GREEN}feature/identity-service/ali/add-oauth2-login${NC}"
        echo ""
        errors=$((errors + 1))
    fi
fi

# ---------------------------------------------------------------------------
# 2. No secrets in staged files
# ---------------------------------------------------------------------------
SECRET_PATTERNS='\.env$|credentials|secret|\.pem$|\.key$'
STAGED_FILES=$(git diff --cached --name-only --diff-filter=ACM 2>/dev/null || true)

if [[ -n "$STAGED_FILES" ]]; then
    SECRET_MATCHES=$(echo "$STAGED_FILES" | grep -iE "$SECRET_PATTERNS" || true)
    if [[ -n "$SECRET_MATCHES" ]]; then
        echo -e "${RED}${BOLD}ERROR:${NC} Potential secrets detected in staged files:"
        echo "$SECRET_MATCHES" | while read -r file; do
            echo -e "  ${RED}- $file${NC}"
        done
        echo ""
        echo -e "  Remove these files from staging: ${YELLOW}git reset HEAD <file>${NC}"
        echo ""
        errors=$((errors + 1))
    fi
fi

# ---------------------------------------------------------------------------
# 3. No debug statements in Java files (warning only)
# ---------------------------------------------------------------------------
if [[ -n "$STAGED_FILES" ]]; then
    JAVA_FILES=$(echo "$STAGED_FILES" | grep '\.java$' || true)
    if [[ -n "$JAVA_FILES" ]]; then
        for file in $JAVA_FILES; do
            DEBUG_LINES=$(git diff --cached "$file" | grep -n '^\+.*System\.\(out\|err\)\.println' || true)
            if [[ -n "$DEBUG_LINES" ]]; then
                echo -e "${YELLOW}${BOLD}WARNING:${NC} Debug statement found in ${YELLOW}$file${NC}:"
                echo "$DEBUG_LINES" | while read -r line; do
                    echo -e "  ${YELLOW}$line${NC}"
                done
                echo ""
                warnings=$((warnings + 1))
            fi
        done
    fi
fi

# ---------------------------------------------------------------------------
# 4. No merge conflict markers
# ---------------------------------------------------------------------------
if [[ -n "$STAGED_FILES" ]]; then
    for file in $STAGED_FILES; do
        # Only check text files that exist
        if [[ -f "$file" ]]; then
            CONFLICT_MARKERS=$(git diff --cached "$file" | grep -E '^\+.*(<{7}|={7}|>{7})' || true)
            if [[ -n "$CONFLICT_MARKERS" ]]; then
                echo -e "${RED}${BOLD}ERROR:${NC} Merge conflict markers found in ${RED}$file${NC}:"
                echo "$CONFLICT_MARKERS" | while read -r line; do
                    echo -e "  ${RED}$line${NC}"
                done
                echo ""
                errors=$((errors + 1))
            fi
        fi
    done
fi

# ---------------------------------------------------------------------------
# 5. Auto-format staged Java files with Spotless (Google Java Format)
# ---------------------------------------------------------------------------
if [[ $errors -eq 0 && -n "$STAGED_FILES" ]]; then
    JAVA_STAGED=$(echo "$STAGED_FILES" | grep '\.java$' || true)
    if [[ -n "$JAVA_STAGED" ]]; then
        SCRIPT_DIR="$(cd "$(dirname "$0")" && pwd)"
        PROJECT_ROOT="$(cd "$SCRIPT_DIR/.." && pwd)"

        echo -e "${YELLOW}Formatting staged Java files with Google Java Format...${NC}"
        if "$PROJECT_ROOT/gradlew" -p "$PROJECT_ROOT" spotlessJavaApply --no-daemon -q 2>&1; then
            # Re-stage any files that were reformatted
            for file in $JAVA_STAGED; do
                if [[ -f "$file" ]]; then
                    git add "$file"
                fi
            done
            echo -e "${GREEN}Formatting applied.${NC}"
        else
            echo -e "${RED}${BOLD}ERROR:${NC} Spotless formatting failed. Fix the issue and try again."
            errors=$((errors + 1))
        fi
    fi
fi

# ---------------------------------------------------------------------------
# Summary
# ---------------------------------------------------------------------------
if [[ $errors -gt 0 ]]; then
    echo -e "${RED}${BOLD}Commit blocked:${NC} $errors error(s) found. Fix the issues above and try again."
    exit 1
fi

if [[ $warnings -gt 0 ]]; then
    echo -e "${YELLOW}${BOLD}Commit proceeding with $warnings warning(s).${NC} Consider fixing them."
fi

exit 0
