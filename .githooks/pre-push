#!/usr/bin/env bash
set -euo pipefail

RED='\033[0;31m'
YELLOW='\033[1;33m'
GREEN='\033[0;32m'
BOLD='\033[1m'
NC='\033[0m'

REMOTE="$1"

PROTECTED_BRANCHES="^(main|master|develop)$"
LOCAL_BRANCH=$(git symbolic-ref --short HEAD 2>/dev/null || echo "HEAD")
IS_HOTFIX=false

if [[ "$LOCAL_BRANCH" =~ ^hotfix/ ]]; then
    IS_HOTFIX=true
fi

# ---------------------------------------------------------------------------
# Read push info from stdin (provided by Git)
# ---------------------------------------------------------------------------
while read -r local_ref local_oid remote_ref remote_oid; do
    REMOTE_BRANCH=$(echo "$remote_ref" | sed 's|refs/heads/||')

    # -----------------------------------------------------------------
    # 1. Block force pushes to protected branches (even from hotfix)
    # -----------------------------------------------------------------
    if [[ "$REMOTE_BRANCH" =~ $PROTECTED_BRANCHES ]]; then
        # Detect force push: if remote_oid is not ancestor of local_oid
        if [[ "$remote_oid" != "0000000000000000000000000000000000000000" ]]; then
            IS_ANCESTOR=$(git merge-base --is-ancestor "$remote_oid" "$local_oid" 2>/dev/null && echo "yes" || echo "no")
            if [[ "$IS_ANCESTOR" == "no" ]]; then
                echo -e "${RED}${BOLD}ERROR:${NC} Force push to ${RED}$REMOTE_BRANCH${NC} is ${RED}blocked${NC}."
                echo -e "  Force pushing to protected branches is never allowed."
                echo ""
                exit 1
            fi
        fi

        # -----------------------------------------------------------------
        # 2. Block direct pushes to protected branches (hotfix exempt)
        # -----------------------------------------------------------------
        if [[ "$IS_HOTFIX" == false ]]; then
            echo -e "${RED}${BOLD}ERROR:${NC} Direct push to ${RED}$REMOTE_BRANCH${NC} is ${RED}blocked${NC}."
            echo ""
            echo -e "  Protected branches require a ${GREEN}Pull Request${NC}."
            echo -e "  Create a PR: ${YELLOW}gh pr create --base $REMOTE_BRANCH${NC}"
            echo ""
            echo -e "  ${YELLOW}Exception:${NC} hotfix/* branches can push directly to protected branches."
            echo ""
            exit 1
        fi
    fi
done

# ---------------------------------------------------------------------------
# 3. Spotless format check (safety net)
# ---------------------------------------------------------------------------
SCRIPT_DIR="$(cd "$(dirname "$0")" && pwd)"
PROJECT_ROOT="$(cd "$SCRIPT_DIR/.." && pwd)"

echo -e "${YELLOW}Checking code formatting (Spotless)...${NC}"
if ! "$PROJECT_ROOT/gradlew" -p "$PROJECT_ROOT" spotlessCheck --no-daemon -q 2>&1; then
    echo ""
    echo -e "${RED}${BOLD}ERROR:${NC} Code is not formatted. Run ${YELLOW}./gradlew spotlessApply${NC} and commit the changes."
    echo ""
    exit 1
fi
echo -e "${GREEN}Formatting check passed.${NC}"

# ---------------------------------------------------------------------------
# 4. Compilation check
# ---------------------------------------------------------------------------
echo -e "${YELLOW}Running compilation check before push...${NC}"

if ! "$PROJECT_ROOT/gradlew" -p "$PROJECT_ROOT" compileJava --no-daemon -q 2>&1; then
    echo ""
    echo -e "${RED}${BOLD}ERROR:${NC} Compilation failed. Fix build errors before pushing."
    echo ""
    exit 1
fi

echo -e "${GREEN}Compilation passed.${NC}"
exit 0
